{
  "name": "yuyingpets-display-app",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "shared",
    "web",
    "desktop",
    "e2e"
  ],
  "scripts": {
    "dev:web": "npm --workspace web run dev",
    "check:display": "npm --workspace web run check:display",
    "build:web": "npm --workspace web run build",
    "dev:desktop": "npm --workspace desktop run dev",
    "build:desktop": "npm --workspace desktop run build",
    "test:e2e": "npm --workspace e2e run test:all"
  }
}
