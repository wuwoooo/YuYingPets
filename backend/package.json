{
  "name": "yuyingpets-backend",
  "version": "0.1.0",
  "private": true,
  "description": "YuYingPets backend service built with NestJS and Prisma",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "pm2:start": "pm2 startOrReload ecosystem.config.cjs --env production",
    "pm2:status": "pm2 status yuyingpets-backend",
    "ops:health": "node scripts/backend-healthcheck.cjs",
    "ops:watchdog": "node scripts/backend-watchdog.cjs",
    "ops:log-report": "node scripts/backend-log-report.cjs",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:db:execute:pet-assets-png": "prisma db execute --schema prisma/schema.prisma --file sql/migrate_pet_assets_to_png_20260424.sql",
    "prisma:db:execute:pet-decorations": "prisma db execute --schema prisma/schema.prisma --file sql/seed_pet_decorations.sql",
    "prisma:db:execute:pet-theme-children-day-2026": "prisma db execute --schema prisma/schema.prisma --file sql/seed_pet_theme_children_day_2026.sql",
    "prisma:db:execute:pet-theme-mini-adventure-2026": "prisma db execute --schema prisma/schema.prisma --file sql/seed_pet_theme_mini_adventure_2026.sql",
    "prisma:db:execute:pet-theme-goldfish-express-2026": "prisma db execute --schema prisma/schema.prisma --file sql/seed_pet_theme_goldfish_express_2026.sql",
    "prisma:db:execute:pet-theme-arcane-library-2026": "prisma db execute --schema prisma/schema.prisma --file sql/seed_pet_theme_arcane_library_2026.sql",
    "prisma:db:execute:pet-theme-ninja-flame-2026": "prisma db execute --schema prisma/schema.prisma --file sql/seed_pet_theme_ninja_flame_2026.sql",
    "pet-decorations:generate-400": "node scripts/generate-pet-decoration-variants.cjs",
    "prisma:studio": "prisma studio",
    "pet-catalog:generate-sql": "node scripts/generate-pet-catalog-sql.cjs",
    "pet-catalog:import": "node scripts/import-pet-catalog.cjs",
    "deploy:seed-default-data": "npm run seed:default && npm run prisma:db:execute:pet-assets-png",
    "pet-growth:reconcile": "node scripts/reconcile-pet-growth.cjs",
    "score-rules:generate-sql": "node scripts/import-score-rules-from-xls.cjs --generate-only",
    "score-rules:import-xls": "node scripts/import-score-rules-from-xls.cjs",
    "reset:business": "ts-node scripts/reset-business-data.ts",
    "reset:teachers": "ts-node scripts/reset-business-data.ts --only=teachers",
    "reset:students": "ts-node scripts/reset-business-data.ts --only=students",
    "reset:classes": "ts-node scripts/reset-business-data.ts --only=classes",
    "reset:schedules": "ts-node scripts/reset-business-data.ts --only=schedules",
    "reset:scores": "ts-node scripts/reset-business-data.ts --only=scores",
    "reset:academics": "ts-node scripts/reset-business-data.ts --only=academics",
    "security:reset-weak-passwords": "ts-node scripts/reset-weak-passwords.ts",
    "seed:default": "ts-node prisma/seed.default.ts",
    "seed:mock": "ts-node prisma/seed.mock.ts",
    "seed:all": "npm run seed:default && npm run seed:mock"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/cache-manager": "^3.1.2",
    "@nestjs/common": "^11.1.24",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.24",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.24",
    "@nestjs/platform-socket.io": "^11.1.24",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/websockets": "^11.1.24",
    "@prisma/client": "^5.22.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.77.6",
    "cache-manager": "^7.2.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "exceljs": "^4.4.0",
    "pino": "^9.14.0",
    "pinyin-pro": "^3.28.1",
    "redis": "^6.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.24",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.1",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.4.2",
    "prisma": "^5.22.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "uuid": "^11.1.0"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
