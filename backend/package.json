{
  "name": "yuyingpets-backend",
  "version": "0.1.0",
  "private": true,
  "description": "YuYingPets backend service built with NestJS and Prisma",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/src/main.js",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:db:execute:pet-assets-png": "prisma db execute --schema prisma/schema.prisma --file sql/migrate_pet_assets_to_png_20260424.sql",
    "prisma:studio": "prisma studio",
    "pet-catalog:generate-sql": "node scripts/generate-pet-catalog-sql.cjs",
    "pet-catalog:import": "node scripts/import-pet-catalog.cjs",
    "deploy:seed-default-data": "npm run seed:default && npm run prisma:db:execute:pet-assets-png",
    "pet-growth:reconcile": "node scripts/reconcile-pet-growth.cjs",
    "score-rules:generate-sql": "node scripts/import-score-rules-from-xls.cjs --generate-only",
    "score-rules:import-xls": "node scripts/import-score-rules-from-xls.cjs",
    "seed:default": "ts-node prisma/seed.default.ts",
    "seed:mock": "ts-node prisma/seed.mock.ts",
    "seed:all": "npm run seed:default && npm run seed:mock"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.8",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.8",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.4.8",
    "@nestjs/platform-socket.io": "^10.4.8",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/websockets": "^10.4.8",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "pinyin-pro": "^3.28.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "swagger-ui-express": "^5.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.8",
    "@nestjs/schematics": "^10.1.4",
    "@nestjs/testing": "^10.4.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.1",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "prisma": "^5.22.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
