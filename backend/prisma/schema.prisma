  @@map("score_record_batch")
}

model ScoreRecordBatchItem {
  id            BigInt   @id @default(autoincrement())
  batchId       BigInt   @map("batch_id")
  scoreRecordId BigInt   @map("score_record_id")
  studentId     BigInt   @map("student_id")
