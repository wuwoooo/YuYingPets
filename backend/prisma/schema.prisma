model AcademicScoreRecord {
  id              BigInt   @id @default(autoincrement())
  schoolId        BigInt   @map("school_id")
  semesterId      BigInt   @map("semester_id")
  examId          BigInt   @map("exam_id")
  classId         BigInt   @map("class_id")
  studentId       BigInt   @map("student_id")
  studentNo       String   @map("student_no") @db.VarChar(64)
  studentName     String   @map("student_name") @db.VarChar(64)
  className       String   @map("class_name") @db.VarChar(64)
  subjectCode     String   @map("subject_code") @db.VarChar(32)
  subjectName     String   @map("subject_name") @db.VarChar(64)
  score           Decimal? @db.Decimal(8, 2)
  jointRank       Int?     @map("joint_rank")
  schoolRank      Int?     @map("school_rank")
  schoolRankDelta Int?     @map("school_rank_delta")
  classRank       Int?     @map("class_rank")
  classRankDelta  Int?     @map("class_rank_delta")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  school    School       @relation(fields: [schoolId], references: [id])
  semester  Semester     @relation(fields: [semesterId], references: [id])
  exam      AcademicExam @relation(fields: [examId], references: [id])
  classroom Classroom    @relation(fields: [classId], references: [id])
  student   Student      @relation(fields: [studentId], references: [id])

  @@unique([examId, studentId, subjectCode])
  @@index([studentId, subjectCode])
  @@index([classId, subjectCode])
  @@index([schoolId, semesterId])
  @@map("academic_score_record")
}

model Pet {
  id          BigInt   @id @default(autoincrement())
  schoolId    BigInt   @map("school_id")
  code        String   @db.VarChar(64)
  name        String   @db.VarChar(64)
  category    String?  @db.VarChar(64)
  rarity      String?  @db.VarChar(32)
  sourceType  String   @default("custom") @map("source_type") @db.VarChar(32)
  coverUrl    String?  @map("cover_url") @db.VarChar(255)
  description String?  @db.VarChar(255)
  status      Status   @default(enabled)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  school      School       @relation(fields: [schoolId], references: [id])
  stages      PetStage[]
  studentPets StudentPet[]

  @@unique([schoolId, code])
  @@index([schoolId])
  @@map("pet")
}

model PetStage {
  id             BigInt   @id @default(autoincrement())
  petId          BigInt   @map("pet_id")
  stageNo        Int      @map("stage_no")
  levelNo        Int      @map("level_no")
  name           String   @db.VarChar(64)
  imageUrl       String   @map("image_url") @db.VarChar(255)
  needScoreTotal Int      @map("need_score_total")
  animationKey   String?  @map("animation_key") @db.VarChar(64)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  pet Pet @relation(fields: [petId], references: [id])

  @@unique([petId, stageNo])
  @@map("pet_stage")
}

model StudentPet {
  id             BigInt    @id @default(autoincrement())
  studentId      BigInt    @unique @map("student_id")
  petId          BigInt    @map("pet_id")
  currentLevel   Int       @default(1) @map("current_level")
  currentStageNo Int       @default(1) @map("current_stage_no")
  totalScore     Int       @default(0) @map("total_score")
  unlockedAt     DateTime? @map("unlocked_at")
  adoptedBy      BigInt?   @map("adopted_by")
  status         Status    @default(enabled)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  student       Student       @relation(fields: [studentId], references: [id])
  pet           Pet           @relation(fields: [petId], references: [id])
  adoptedByUser User?         @relation("StudentPetAdoptedBy", fields: [adoptedBy], references: [id])
  levelLogs     PetLevelLog[]

  @@map("student_pet")
}

model PetLevelLog {
  id                   BigInt   @id @default(autoincrement())
  studentPetId         BigInt   @map("student_pet_id")
  studentId            BigInt   @map("student_id")
  beforeLevel          Int      @map("before_level")
  afterLevel           Int      @map("after_level")
  beforeStageNo        Int      @map("before_stage_no")
  afterStageNo         Int      @map("after_stage_no")
