generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Status {
  enabled
  disabled
}

enum ScopeType {
  school
  grade
  class_scope
  subject_class
}

enum ModuleType {
  general
  subject
}

enum ScoreType {
  add
  deduct
}

enum ScoreMode {
  fixed
}

enum ScoreTarget {
  student
  class
}

enum Sentiment {
  positive
  negative
}

enum TerminalType {
  admin
  display
}

enum HonorCategory {
  personal
  collective
  phase
  longterm
}

enum RewardOrderStatus {
  received
  cancelled
}

enum DisplayUnlockStatus {
  active
  expired
  locked
}

enum PeriodType {
  weekly
  monthly
}

enum GeneratedBy {
  manual
}

enum TeacherClassRole {
  homeroom
  co_homeroom
  subject_teacher
}

model School {
  id                  BigInt   @id @default(autoincrement())
  code                String   @unique @db.VarChar(64)
  name                String   @db.VarChar(128)
  englishName         String?  @map("english_name") @db.VarChar(255)
  motto               String?  @db.VarChar(255)
  logoUrl             String?  @map("logo_url") @db.VarChar(255)
  emblemUrl           String?  @map("emblem_url") @db.VarChar(255)
  phone               String?  @db.VarChar(32)
  address             String?  @db.VarChar(255)
  petGrowthThresholds Json?    @map("pet_growth_thresholds")
  classScoreStudentLinkMultiplier Int @default(0) @map("class_score_student_link_multiplier")
  status              Status   @default(enabled)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  semesters                   Semester[]
  roles                       Role[]
  users                       User[]
  classrooms                  Classroom[]
  gradeConfigs                GradeConfig[]
  students                    Student[]
  scoreRules                  ScoreRule[]
  scoreRecords                ScoreRecord[]
  scoreRecordBatches          ScoreRecordBatch[]
  academicExams               AcademicExam[]
  academicScoreRecords        AcademicScoreRecord[]
  classScoreProfiles          ClassScoreProfile[]
  classScoreRecords           ClassScoreRecord[]
  classScoreBatches           ClassScoreRecordBatch[]
  pets                        Pet[]
  honors                      Honor[]
  honorRecords                HonorRecord[]
  rewards                     Reward[]
  rewardOrders                RewardOrder[]
  displayConfigs              DisplayConfig[]
  displayTerminals            DisplayTerminal[]
  aiStudentSnapshots          AiStudentSnapshot[]
  teacherClassAssignments     TeacherClassAssignment[]
  teacherObservations         TeacherObservation[]
  teacherScheduleSlots        TeacherScheduleSlot[]
  pendingTeacherScheduleSlots PendingTeacherScheduleSlot[]
  teacherOccupancyRules       TeacherOccupancyRule[]
  operationLogs               OperationLog[]

  @@map("school")
}

model Semester {
  id        BigInt   @id @default(autoincrement())
  schoolId  BigInt   @map("school_id")
  name      String   @db.VarChar(128)
  startDate DateTime @map("start_date") @db.Date
  endDate   DateTime @map("end_date") @db.Date
  isCurrent Boolean  @default(false) @map("is_current")
  status    Status   @default(enabled)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  school               School                @relation(fields: [schoolId], references: [id])
  classrooms           Classroom[]
  scoreRules           ScoreRule[]
  scoreRecords         ScoreRecord[]
  academicExams        AcademicExam[]
  academicScoreRecords AcademicScoreRecord[]
  classScoreProfiles   ClassScoreProfile[]
  classScoreRecords    ClassScoreRecord[]
  aiStudentSnapshots   AiStudentSnapshot[]

  @@index([schoolId])
  @@index([schoolId, isCurrent])
  @@map("semester")
}

model Role {
  id          BigInt   @id @default(autoincrement())
  schoolId    BigInt   @map("school_id")
  code        String   @db.VarChar(64)
  name        String   @db.VarChar(64)
  description String?  @db.VarChar(255)
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  school          School              @relation(fields: [schoolId], references: [id])
  users           User[]
  rolePermissions RolePermissionRel[]

  @@index([schoolId])
  @@map("role")
}

model Permission {
  id          BigInt   @id @default(autoincrement())
  code        String   @unique @db.VarChar(128)
  name        String   @db.VarChar(128)
  module      String   @db.VarChar(64)
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  rolePermissions RolePermissionRel[]

  @@map("permission")
}

model RolePermissionRel {
  id           BigInt   @id @default(autoincrement())
  roleId       BigInt   @map("role_id")
  permissionId BigInt   @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at")

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@map("role_permission_rel")
}

model User {
  id           BigInt    @id @default(autoincrement())
  schoolId     BigInt    @map("school_id")
  roleId       BigInt    @map("role_id")
  username     String    @unique @db.VarChar(64)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  name         String    @db.VarChar(64)
  phone        String?   @db.VarChar(32)
  email        String?   @db.VarChar(128)
  dutyTags     Json?     @map("duty_tags")
  status       Status    @default(enabled)
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  school                      School                   @relation(fields: [schoolId], references: [id])
  role                        Role                     @relation(fields: [roleId], references: [id])
  scopes                      UserScope[]
  homeroomClasses             Classroom[]              @relation("HomeroomTeacherClasses")
  scoreRecords                ScoreRecord[]
  classScoreRecords           ClassScoreRecord[]
  classScoreBatches           ClassScoreRecordBatch[]
  createdScoreRules           ScoreRule[]              @relation("ScoreRuleCreatedBy")
  updatedScoreRules           ScoreRule[]              @relation("ScoreRuleUpdatedBy")
  rewardOrders                RewardOrder[]
  honorRecords                HonorRecord[]
  displayUnlockSessions       DisplayUnlockSession[]
  initializedDisplayTerminals DisplayTerminal[]        @relation("DisplayTerminalInitializedBy")
  adoptedStudentPets          StudentPet[]             @relation("StudentPetAdoptedBy")
  teacherClassAssignments     TeacherClassAssignment[]
  teacherObservations         TeacherObservation[]
  teacherScheduleSlots        TeacherScheduleSlot[]
  operationLogs               OperationLog[]

  @@index([schoolId])
  @@index([roleId])
  @@map("user")
}

model UserScope {
  id          BigInt    @id @default(autoincrement())
  userId      BigInt    @map("user_id")
  scopeType   ScopeType @map("scope_type")
  gradeCode   String?   @map("grade_code") @db.VarChar(32)
  classId     BigInt?   @map("class_id")
  subjectCode String?   @map("subject_code") @db.VarChar(32)
  createdAt   DateTime  @default(now()) @map("created_at")

  user      User       @relation(fields: [userId], references: [id])
  classroom Classroom? @relation(fields: [classId], references: [id])

  @@index([userId])
  @@map("user_scope")
}

model Classroom {
  id                  BigInt    @id @default(autoincrement())
  schoolId            BigInt    @map("school_id")
  semesterId          BigInt    @map("semester_id")
  code                String    @db.VarChar(64)
  gradeCode           String    @map("grade_code") @db.VarChar(32)
  gradeName           String    @map("grade_name") @db.VarChar(32)
  name                String    @db.VarChar(64)
  homeroomTeacherId   BigInt?   @map("homeroom_teacher_id")
  slogan              String?   @db.VarChar(255)
  targetScore         Int?      @map("target_score")
  countdownTitle      String?   @map("countdown_title") @db.VarChar(128)
  countdownDeadlineAt DateTime? @map("countdown_deadline_at")
  displayStatus       String?   @map("display_status") @db.VarChar(32)
  sortOrder           Int?      @map("sort_order")
  status              Status    @default(enabled)
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  school                      School                       @relation(fields: [schoolId], references: [id])
  semester                    Semester                     @relation(fields: [semesterId], references: [id])
  homeroomTeacher             User?                        @relation("HomeroomTeacherClasses", fields: [homeroomTeacherId], references: [id])
  students                    Student[]
  userScopes                  UserScope[]
  teacherClassAssignments     TeacherClassAssignment[]
  classGroups                 ClassGroup[]
  studentProfiles             StudentProfile[]
  scoreRecords                ScoreRecord[]
  scoreRecordBatches          ScoreRecordBatch[]
  academicScoreRecords        AcademicScoreRecord[]
  classScoreProfile           ClassScoreProfile?
  classScoreRecords           ClassScoreRecord[]
  honorRecords                HonorRecord[]
  rewardOrders                RewardOrder[]
  displayConfigs              DisplayConfig[]
  displayTerminals            DisplayTerminal[]
  displayUnlockSessions       DisplayUnlockSession[]
  aiStudentSnapshots          AiStudentSnapshot[]
  teacherObservations         TeacherObservation[]
  teacherScheduleSlots        TeacherScheduleSlot[]
  pendingTeacherScheduleSlots PendingTeacherScheduleSlot[]

  @@index([schoolId, semesterId])
  @@index([gradeCode])
  @@index([homeroomTeacherId])
  @@map("class")
}

model TeacherClassAssignment {
  id          BigInt           @id @default(autoincrement())
  schoolId    BigInt           @map("school_id")
  teacherId   BigInt           @map("teacher_id")
  classId     BigInt           @map("class_id")
  roleInClass TeacherClassRole @map("role_in_class")
  subjectCode String?          @map("subject_code") @db.VarChar(32)
  isPrimary   Boolean          @default(false) @map("is_primary")
  status      Status           @default(enabled)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  school    School    @relation(fields: [schoolId], references: [id])
  teacher   User      @relation(fields: [teacherId], references: [id])
  classroom Classroom @relation(fields: [classId], references: [id])

  @@index([schoolId, classId, roleInClass])
  @@index([schoolId, teacherId])
  @@index([teacherId, classId])
  @@map("teacher_class_assignment")
}

model TeacherScheduleSlot {
  id         BigInt   @id @default(autoincrement())
  schoolId   BigInt   @map("school_id")
  teacherId  BigInt   @map("teacher_id")
  classId    BigInt?  @map("class_id")
  weekday    Int
  periodNo   Int      @map("period_no")
  startTime  String   @map("start_time") @db.VarChar(8)
  endTime    String   @map("end_time") @db.VarChar(8)
  subject    String   @db.VarChar(64)
  className  String?  @map("class_name") @db.VarChar(32)
  sourceFile String?  @map("source_file") @db.VarChar(255)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  school    School     @relation(fields: [schoolId], references: [id])
  teacher   User       @relation(fields: [teacherId], references: [id])
  classroom Classroom? @relation(fields: [classId], references: [id])

  @@index([schoolId, teacherId, weekday])
  @@index([schoolId, weekday, startTime, endTime])
  @@index([schoolId, classId])
  @@map("teacher_schedule_slot")
}

model PendingTeacherScheduleSlot {
  id          BigInt   @id @default(autoincrement())
  schoolId    BigInt   @map("school_id")
  classId     BigInt?  @map("class_id")
  teacherName String   @map("teacher_name") @db.VarChar(64)
  weekday     Int
  periodNo    Int      @map("period_no")
  startTime   String   @map("start_time") @db.VarChar(8)
  endTime     String   @map("end_time") @db.VarChar(8)
  subject     String   @db.VarChar(64)
  className   String?  @map("class_name") @db.VarChar(32)
  sourceFile  String?  @map("source_file") @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  school    School     @relation(fields: [schoolId], references: [id])
  classroom Classroom? @relation(fields: [classId], references: [id])

  @@index([schoolId, teacherName])
  @@index([schoolId, weekday, startTime, endTime])
  @@index([schoolId, classId])
  @@map("pending_teacher_schedule_slot")
}

model TeacherOccupancyRule {
  id           BigInt   @id @default(autoincrement())
  schoolId     BigInt   @map("school_id")
  ruleType     String   @default("research") @map("rule_type") @db.VarChar(32)
  name         String   @db.VarChar(128)
  weekdays     Json
  subjectCodes Json     @map("subject_codes")
  startTime    String   @map("start_time") @db.VarChar(8)
  endTime      String   @map("end_time") @db.VarChar(8)
  status       Status   @default(enabled)
  remark       String?  @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  school School @relation(fields: [schoolId], references: [id])

  @@index([schoolId, ruleType, status])
  @@map("teacher_occupancy_rule")
}

model GradeConfig {
  id        BigInt    @id @default(autoincrement())
  schoolId  BigInt    @map("school_id")
  code      String    @db.VarChar(32)
  name      String    @db.VarChar(32)
  sortOrder Int?      @map("sort_order")
  status    Status    @default(enabled)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  school School @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, code])
  @@index([schoolId])
  @@index([schoolId, status])
  @@map("grade_config")
}

model Student {
  id        BigInt    @id @default(autoincrement())
  schoolId  BigInt    @map("school_id")
  classId   BigInt    @map("class_id")
  studentNo String    @map("student_no") @db.VarChar(64)
  name      String    @db.VarChar(64)
  gender    String?   @db.VarChar(16)
  avatarUrl String?   @map("avatar_url") @db.VarChar(255)
  status    Status    @default(enabled)
  joinedAt  DateTime? @map("joined_at") @db.Date
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  school                School                 @relation(fields: [schoolId], references: [id])
  classroom             Classroom              @relation(fields: [classId], references: [id])
  profile               StudentProfile?
  groupRel              StudentGroupRel?
  scoreRecords          ScoreRecord[]
  scoreRecordBatchItems ScoreRecordBatchItem[]
  academicScoreRecords  AcademicScoreRecord[]
  studentPet            StudentPet?
  petLevelLogs          PetLevelLog[]
  honorRecords          HonorRecord[]
  rewardOrders          RewardOrder[]
  aiStudentSnapshots    AiStudentSnapshot[]
  teacherObservations   TeacherObservation[]

  @@unique([classId, studentNo])
  @@index([schoolId])
  @@index([classId])
  @@map("student")
}

model StudentProfile {
  id              BigInt    @id @default(autoincrement())
  studentId       BigInt    @unique @map("student_id")
  classId         BigInt    @map("class_id")
  currentScore    Int       @default(0) @map("current_score")
  totalScore      Int       @default(0) @map("total_score")
  currentPetLevel Int       @default(1) @map("current_pet_level")
  medalsCount     Int       @default(0) @map("medals_count")
  honorsCount     Int       @default(0) @map("honors_count")
  rewardsCount    Int       @default(0) @map("rewards_count")
  positiveCount7d Int       @default(0) @map("positive_count_7d")
  negativeCount7d Int       @default(0) @map("negative_count_7d")
  lastScoreAt     DateTime? @map("last_score_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  student   Student   @relation(fields: [studentId], references: [id])
  classroom Classroom @relation(fields: [classId], references: [id])

  @@index([classId])
  @@map("student_profile")
}

model ClassGroup {
  id        BigInt   @id @default(autoincrement())
  classId   BigInt   @map("class_id")
  groupNo   Int      @map("group_no")
  name      String   @db.VarChar(64)
  sortOrder Int?     @map("sort_order")
  status    Status   @default(enabled)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  classroom        Classroom         @relation(fields: [classId], references: [id])
  studentGroupRels StudentGroupRel[]
  scoreRecords     ScoreRecord[]

  @@unique([classId, groupNo])
  @@map("class_group")
}

model StudentGroupRel {
  id           BigInt   @id @default(autoincrement())
  studentId    BigInt   @unique @map("student_id")
  classGroupId BigInt   @map("class_group_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  student    Student    @relation(fields: [studentId], references: [id])
  classGroup ClassGroup @relation(fields: [classGroupId], references: [id])

  @@map("student_group_rel")
}

model ScoreRule {
  id               BigInt      @id @default(autoincrement())
  schoolId         BigInt      @map("school_id")
  semesterId       BigInt      @map("semester_id")
  moduleType       ModuleType  @map("module_type")
  subjectCode      String?     @map("subject_code") @db.VarChar(32)
  sceneCode        String      @map("scene_code") @db.VarChar(32)
  code             String      @db.VarChar(64)
  name             String      @db.VarChar(128)
  scoreType        ScoreType   @map("score_type")
  scoreMode        ScoreMode   @default(fixed) @map("score_mode")
  scoreTarget      ScoreTarget @default(student) @map("score_target")
  scoreValue       Int         @map("score_value")
  minScore         Int?        @map("min_score")
  maxScore         Int?        @map("max_score")
  dimension        String?     @db.VarChar(64)
  tag              String?     @db.VarChar(64)
  sentiment        Sentiment
  weight           Decimal?    @db.Decimal(6, 2)
  aiSummaryText    String?     @map("ai_summary_text") @db.VarChar(255)
  description      String?     @db.VarChar(500)
  allowedRoleCodes String?     @map("allowed_role_codes") @db.VarChar(255)
  isHighFrequency  Boolean     @default(false) @map("is_high_frequency")
  displayEnabled   Boolean     @default(false) @map("display_enabled")
  adminEnabled     Boolean     @default(true) @map("admin_enabled")
  status           Status      @default(enabled)
  createdBy        BigInt?     @map("created_by")
  updatedBy        BigInt?     @map("updated_by")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")
  deletedAt        DateTime?   @map("deleted_at")

  school             School                  @relation(fields: [schoolId], references: [id])
  semester           Semester                @relation(fields: [semesterId], references: [id])
  createdByUser      User?                   @relation("ScoreRuleCreatedBy", fields: [createdBy], references: [id])
  updatedByUser      User?                   @relation("ScoreRuleUpdatedBy", fields: [updatedBy], references: [id])
  scoreRecords       ScoreRecord[]
  scoreRecordBatches ScoreRecordBatch[]
  classScoreRecords  ClassScoreRecord[]
  classScoreBatches  ClassScoreRecordBatch[]

  @@index([schoolId, semesterId])
  @@index([moduleType, subjectCode, sceneCode])
  @@index([scoreTarget])
  @@index([displayEnabled])
  @@map("score_rule")
}

model ClassScoreProfile {
  id              BigInt    @id @default(autoincrement())
  schoolId        BigInt    @map("school_id")
  semesterId      BigInt    @map("semester_id")
  classId         BigInt    @unique @map("class_id")
  currentScore    Int       @default(0) @map("current_score")
  totalScore      Int       @default(0) @map("total_score")
  positiveCount7d Int       @default(0) @map("positive_count_7d")
  negativeCount7d Int       @default(0) @map("negative_count_7d")
  lastScoreAt     DateTime? @map("last_score_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  school    School    @relation(fields: [schoolId], references: [id])
  semester  Semester  @relation(fields: [semesterId], references: [id])
  classroom Classroom @relation(fields: [classId], references: [id])

  @@index([schoolId, semesterId])
  @@map("class_score_profile")
}

model ClassScoreRecord {
  id             BigInt       @id @default(autoincrement())
  schoolId       BigInt       @map("school_id")
  semesterId     BigInt       @map("semester_id")
  classId        BigInt       @map("class_id")
  batchId        BigInt?      @map("batch_id")
  ruleId         BigInt       @map("rule_id")
  subjectCode    String?      @map("subject_code") @db.VarChar(32)
  sceneCode      String?      @map("scene_code") @db.VarChar(32)
  dimension      String?      @db.VarChar(64)
  tag            String?      @db.VarChar(64)
  sentiment      Sentiment
  scoreDelta     Int          @map("score_delta")
  remark         String?      @db.VarChar(255)
  sourceTerminal TerminalType @map("source_terminal")
  sourceRole     String?      @map("source_role") @db.VarChar(32)
  operatorId     BigInt       @map("operator_id")
  operatorName   String?      @map("operator_name") @db.VarChar(64)
  createdAt      DateTime     @default(now()) @map("created_at")

  school    School                 @relation(fields: [schoolId], references: [id])
  semester  Semester               @relation(fields: [semesterId], references: [id])
  classroom Classroom              @relation(fields: [classId], references: [id])
  batch     ClassScoreRecordBatch? @relation(fields: [batchId], references: [id])
  rule      ScoreRule              @relation(fields: [ruleId], references: [id])
  operator  User                   @relation(fields: [operatorId], references: [id])

  @@index([classId, createdAt])
  @@index([ruleId])
  @@index([schoolId, semesterId])
  @@index([batchId])
  @@map("class_score_record")
}

model ClassScoreRecordBatch {
  id             BigInt       @id @default(autoincrement())
  schoolId       BigInt       @map("school_id")
  ruleId         BigInt       @map("rule_id")
  scoreDelta     Int          @map("score_delta")
  remark         String?      @db.VarChar(255)
  sourceTerminal TerminalType @map("source_terminal")
  sourceRole     String?      @map("source_role") @db.VarChar(32)
  operatorId     BigInt       @map("operator_id")
  operatorName   String?      @map("operator_name") @db.VarChar(64)
  createdAt      DateTime     @default(now()) @map("created_at")

  school   School             @relation(fields: [schoolId], references: [id])
  rule     ScoreRule          @relation(fields: [ruleId], references: [id])
  operator User               @relation(fields: [operatorId], references: [id])
  records  ClassScoreRecord[]

  @@index([schoolId, createdAt])
  @@index([ruleId])
  @@map("class_score_record_batch")
}

model ScoreRecord {
  id             BigInt       @id @default(autoincrement())
  schoolId       BigInt       @map("school_id")
  semesterId     BigInt       @map("semester_id")
  classId        BigInt       @map("class_id")
  studentId      BigInt       @map("student_id")
  classGroupId   BigInt?      @map("class_group_id")
  ruleId         BigInt       @map("rule_id")
  subjectCode    String?      @map("subject_code") @db.VarChar(32)
  sceneCode      String?      @map("scene_code") @db.VarChar(32)
  dimension      String?      @db.VarChar(64)
  tag            String?      @db.VarChar(64)
  sentiment      Sentiment
  scoreDelta     Int          @map("score_delta")
  remark         String?      @db.VarChar(255)
  sourceTerminal TerminalType @map("source_terminal")
  sourceRole     String?      @map("source_role") @db.VarChar(32)
  operatorId     BigInt       @map("operator_id")
  operatorName   String?      @map("operator_name") @db.VarChar(64)
  createdAt      DateTime     @default(now()) @map("created_at")

  school       School                 @relation(fields: [schoolId], references: [id])
  semester     Semester               @relation(fields: [semesterId], references: [id])
  classroom    Classroom              @relation(fields: [classId], references: [id])
  student      Student                @relation(fields: [studentId], references: [id])
  classGroup   ClassGroup?            @relation(fields: [classGroupId], references: [id])
  rule         ScoreRule              @relation(fields: [ruleId], references: [id])
  operator     User                   @relation(fields: [operatorId], references: [id])
  petLevelLogs PetLevelLog[]
  batchItems   ScoreRecordBatchItem[]

  @@index([studentId, createdAt])
  @@index([classId, createdAt])
  @@index([ruleId])
  @@index([subjectCode, sceneCode])
