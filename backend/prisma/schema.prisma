  observationType String?   @map("observation_type") @db.VarChar(32)
  content         String    @db.Text
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  classroom       Classroom @relation(fields: [classId], references: [id])
  school          School    @relation(fields: [schoolId], references: [id])
  student         Student   @relation(fields: [studentId], references: [id])
  teacher         User      @relation(fields: [teacherId], references: [id])

  @@index([studentId, createdAt])
  @@index([classId], map: "teacher_observation_class_id_fkey")
  @@index([schoolId], map: "teacher_observation_school_id_fkey")
  @@index([teacherId], map: "teacher_observation_teacher_id_fkey")
  @@map("teacher_observation")
}

model OperationLog {
  id           BigInt       @id @default(autoincrement())
  schoolId     BigInt       @map("school_id")
  userId       BigInt?      @map("user_id")
  roleCode     String?      @map("role_code") @db.VarChar(32)
  terminalType TerminalType @map("terminal_type")
  module       String       @db.VarChar(64)
  action       String       @db.VarChar(64)
  targetType   String?      @map("target_type") @db.VarChar(32)
  targetId     BigInt?      @map("target_id")
  detail       Json?
  createdAt    DateTime     @default(now()) @map("created_at")
  school       School       @relation(fields: [schoolId], references: [id])
  user         User?        @relation(fields: [userId], references: [id])

  @@index([schoolId, createdAt])
  @@index([userId, createdAt])
  @@map("operation_log")
}

model CallQueue {
  id             BigInt   @id @default(autoincrement())
  schoolId       BigInt   @map("school_id")
  classId        BigInt   @map("class_id")
  location       String   @map("location") @db.VarChar(128)
  callerId       BigInt   @map("caller_id")
  callerName     String   @map("caller_name") @db.VarChar(64)
  calledStudents Json     @map("called_students")
  status         String   @default("pending") @db.VarChar(32)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([schoolId])
  @@index([classId, status])
  @@map("call_queue")
}

